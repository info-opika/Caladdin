# Anthropic
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database password (Dashboard → Project Settings → Database) — for npm run db:apply / db:push
SUPABASE_DB_PASSWORD=

# Optional: full Postgres URL instead of SUPABASE_DB_PASSWORD
# DATABASE_URL=postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# App (local dev)
CALADDIN_BASE_URL=http://localhost:3001
CALADDIN_API_KEY=
SESSION_SECRET=change-me-in-production
OAUTH_STATE_SECRET=change-me-in-production
NODE_ENV=development
PORT=3001

# Production (Render) — set in Dashboard, not in committed .env:
# NODE_ENV=production
# PORT=3000
# CALADDIN_BASE_URL=https://your-app.onrender.com
# GOOGLE_REDIRECT_URI=https://your-app.onrender.com/auth/callback
# SESSION_SECRET=<32+ random chars>
# OAUTH_STATE_SECRET=<32+ random chars>
# CALADDIN_API_KEY=<24+ random chars>

# ntfy
NTFY_TOPIC=caladdin-agent
NTFY_USER_TOPIC=caladdin-user

# Pilot cap (Render Blueprint default: 10)
MAX_PILOT_USERS=10
CALADDIN_KILL_SWITCH=0

# Optional: Redis rate-limit backend (Postgres used when unset)
# REDIS_URL=redis://localhost:6379

RESEND_API_KEY=
EMAIL_FROM=Caladdin <onboarding@caladdin.app>
