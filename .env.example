# Anthropic
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database password (Dashboard → Project Settings → Database) — for npm run db:apply / db:push
SUPABASE_DB_PASSWORD=

# Optional: full Postgres URL instead of SUPABASE_DB_PASSWORD
# DATABASE_URL=postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# App
CALADDIN_BASE_URL=http://localhost:3001
CALADDIN_API_KEY=
SESSION_SECRET=change-me-in-production
NODE_ENV=development
PORT=3001

# ntfy
NTFY_TOPIC=caladdin-agent
NTFY_USER_TOPIC=caladdin-user

# Optional: OAuth state signing
OAUTH_STATE_SECRET=change-me-in-production

# Pilot cap (default 25; set to 10 for initial MVP)
MAX_PILOT_USERS=10
CALADDIN_KILL_SWITCH=0

# Optional: Redis rate-limit backend (Postgres used when unset)
# REDIS_URL=redis://localhost:6379

RESEND_API_KEY=
EMAIL_FROM=Caladdin <onboarding@caladdin.app>
